# ── Python artefacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Dev/test files ────────────────────────────────────────────────────────────

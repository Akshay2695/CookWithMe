# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Model selection ────────────────────────────────────────────────────────────
# gemini-2.0-flash-001 gives the best vision quality.
# gemini-2.0-flash-lite-001 is cheaper but slightly lower quality.
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── Rate limits (Gemini free tier: 15 RPM / 1M TPM) ──────────────────────────
GEMINI_RPM=15
GEMINI_TPM=1000000

# ── Browser Configuration ─────────────────────────────────────────────────────
# Set BROWSER_HEADLESS=true on Cloud Run / any headless environment.
# Set to false locally to see the browser during development.
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=100
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=800

# ── Agent Configuration ───────────────────────────────────────────────────────
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.70
ACTION_DELAY_MIN=300
ACTION_DELAY_MAX=800

# Directories
SCREENSHOT_DIR=./screenshots     # Where to save debug screenshots
SESSION_DIR=./sessions           # Where to save login session cookies


# Google Gemini API Key (if using Google Gemini instead of Azure OpenAI)
GOOGLE_API_KEY=your_google_api_key_here